VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Hub-first authentication.
# The hub should redirect back to BroadcastPilot with access_token and refresh_token after login.
VITE_HUB_LOGIN_URL=http://localhost:3000/login
VITE_HUB_LOGOUT_URL=http://localhost:3000/logout

# Keep false in production. Enable only when developing BroadcastPilot standalone.
VITE_ENABLE_LOCAL_AUTH=false
