PORT=3001
PUBLIC_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated browser origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# BullMQ / background jobs
REDIS_URL=redis://127.0.0.1:6380

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

META_CLIENT_ID=
META_CLIENT_SECRET=
META_VERIFY_TOKEN=

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Platform-managed SMS sending.
# These must be real Twilio project credentials. Invalid values cause SMS broadcasts to fail authentication.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+15551234567

# Optional: show and send GAP Whatsapp chats from BroadcastPilot Inbox.
# Keep disabled until the GAP API URL and paths are verified. This does not change GAP tables.
GAP_WHATSAPP_ENABLED=false
GAP_WHATSAPP_API_URL=http://localhost:5001
GAP_WHATSAPP_API_KEY=
GAP_WHATSAPP_ORGANIZATION_ID=
GAP_WHATSAPP_TIMEOUT_MS=12000
GAP_WHATSAPP_CONVERSATIONS_PATH=/api/conversations
GAP_WHATSAPP_MESSAGES_LIMIT=200
GAP_WHATSAPP_MESSAGES_PATH=/api/messages/:conversationId
GAP_WHATSAPP_SEND_MESSAGE_PATH=/api/conversations/:conversationId/send
